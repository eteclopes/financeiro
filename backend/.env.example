# Copie este arquivo para .env e preencha com seus valores reais.
# Nunca commitar o .env real no repositorio.

# String de conexao do PostgreSQL (Supabase). Pegue em: Project Settings > Database > Connection string (URI)
# Use a "Connection pooling" (porta 6543) em producao no Render.
DATABASE_URL="postgresql://postgres:SUASENHA@db.xxxxxxxxxxxx.supabase.co:5432/postgres"

PORT=3333
NODE_ENV=development

# Origem permitida para CORS (URL do frontend React)
CORS_ORIGIN="http://localhost:5173"

# Segredos JWT — gere valores aleatorios fortes (ex: openssl rand -hex 64)
JWT_ACCESS_SECRET="troque-este-valor-por-um-segredo-forte-de-access-token"
JWT_ACCESS_EXPIRES_IN="15m"

JWT_REFRESH_EXPIRES_IN_DAYS=30

# Reset de senha
PASSWORD_RESET_EXPIRES_IN_HOURS=1
